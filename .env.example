# Convex deployment URL (set by init_app_project tool or npx convex dev)
VITE_CONVEX_URL=

# For local development with npx convex dev
# CONVEX_DEPLOY_KEY=

# Auth private key (RSA 2048, generated automatically)
# AUTH_PRIVATE_KEY=

# ── External Integrations ──────────────────────────────────────────────
# Slack incoming webhook URL for real-time notifications
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Resend API key for sending customer update emails
# Sign up at: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email sender address (must be verified in Resend)
FROM_EMAIL=updates@yourdomain.com

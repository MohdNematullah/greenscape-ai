# Convex deployment URL (set by init_app_project tool or npx convex dev)
VITE_CONVEX_URL=

# For local development with npx convex dev
# CONVEX_DEPLOY_KEY=

# Auth private key (RSA 2048, generated automatically)
# AUTH_PRIVATE_KEY=

# ── GoHighLevel (GHL) Integration ─────────────────────────────────────
# Connect your GHL CRM for two-way lead sync, contact import, and pipeline updates.
# GHL → Greenscape AI: webhook auto-creates leads from new GHL contacts
# Greenscape AI → GHL: qualified leads push back as contacts + opportunities
#
# How to get:
#   API Key:     GHL → Settings → API Keys → Create new key
#   Location ID: GHL → Settings → Business Info (sub-account ID)
#   Pipeline ID: GHL → Pipelines → select your pipeline → copy ID from URL (optional)
#
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here
GHL_PIPELINE_ID=your_ghl_pipeline_id_here

# GHL Webhook URL (paste this in GHL → Settings → Webhooks):
# https://<your-convex-deployment>.convex.site/api/ghl/webhook
# Events to enable: Contact Created, Contact Updated, Opportunity Status Changed

# ── Slack Notifications ────────────────────────────────────────────────
# Real-time team alerts for leads, proposals, approvals, and daily digest.
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Email (Resend) ─────────────────────────────────────────────────────
# Branded HTML emails to clients for project updates.
# Sign up (free): https://resend.com — 3,000 emails/month free tier
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender email address — must be verified in your Resend account
FROM_EMAIL=updates@yourdomain.com
